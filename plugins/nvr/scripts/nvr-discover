#!/bin/bash
# nvr-discover - Find the neovim socket that owns a directory.
#
# Matching strategy (in order):
#   1. $NVIM_SOCKET environment override
#   2. Git root match — query each neovim instance for its git root
#      (immune to :lcd changes from autocmds). Pick the socket whose
#      git root is the longest prefix of DIR.
#   3. Closest parent cwd match — fall back to getcwd() matching,
#      picking the socket whose cwd is the longest prefix of DIR.
#
# Usage: nvr-discover [directory]
# Returns: Socket path on stdout (exit 0), error on stderr (exit 1)

set -euo pipefail

DIR="${1:-$(pwd)}"

# ---- environment override ------------------------------------------------

if [[ -n "${NVIM_SOCKET:-}" ]]; then
    if [[ -S "$NVIM_SOCKET" ]]; then
        echo "$NVIM_SOCKET"
        exit 0
    else
        echo "Error: NVIM_SOCKET=$NVIM_SOCKET is not a valid socket" >&2
        exit 1
    fi
fi

# ---- prerequisites -------------------------------------------------------

if ! command -v nvr &>/dev/null; then
    echo "Error: nvr (neovim-remote) not found. Install: pip install neovim-remote" >&2
    exit 1
fi

mapfile -t SOCKETS < <(nvr --serverlist 2>/dev/null | sort -u || true)

if [[ ${#SOCKETS[@]} -eq 0 ]]; then
    echo "Error: No neovim instances found" >&2
    echo "Start neovim with: nvim" >&2
    exit 1
fi

# ---- pass 1: git root match (preferred) ---------------------------------

best_socket=""
best_len=0

for socket in "${SOCKETS[@]}"; do
    git_root=$(timeout 2 nvr --servername "$socket" \
        --remote-expr "trim(system('git -C ' . getcwd() . ' rev-parse --show-toplevel 2>/dev/null'))" \
        2>/dev/null || true)

    # Skip if no git root (non-git directory or query failed).
    [[ -z "$git_root" ]] && continue

    # DIR must be inside or equal to the git root.
    if [[ "$DIR" == "$git_root" ]] || [[ "$DIR" == "$git_root"/* ]]; then
        len=${#git_root}
        if (( len > best_len )); then
            best_socket="$socket"
            best_len=$len
        fi
    fi
done

if [[ -n "$best_socket" ]]; then
    echo "$best_socket"
    exit 0
fi

# ---- pass 2: closest parent cwd match (fallback) ------------------------

best_socket=""
best_len=0

for socket in "${SOCKETS[@]}"; do
    cwd=$(timeout 2 nvr --servername "$socket" --remote-expr 'getcwd()' 2>/dev/null || true)
    [[ -z "$cwd" ]] && continue

    if [[ "$DIR" == "$cwd" ]] || [[ "$DIR" == "$cwd"/* ]]; then
        len=${#cwd}
        if (( len > best_len )); then
            best_socket="$socket"
            best_len=$len
        fi
    fi
done

if [[ -n "$best_socket" ]]; then
    echo "$best_socket"
    exit 0
fi

# ---- no match ------------------------------------------------------------

echo "Error: No neovim instance found for directory: $DIR" >&2
echo "Available instances:" >&2
for socket in "${SOCKETS[@]}"; do
    cwd=$(timeout 2 nvr --servername "$socket" --remote-expr 'getcwd()' 2>&1) || continue
    [[ -z "$cwd" || "$cwd" == *"No valid"* ]] && continue
    echo "  - $cwd (socket: $socket)" >&2
done
exit 1
