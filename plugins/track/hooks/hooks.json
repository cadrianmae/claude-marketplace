{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|Grep|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/capture-sources.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/capture-prompt.sh",
            "async": true,
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
